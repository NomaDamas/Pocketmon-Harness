MGBA_HTTP_BASE_URL=http://127.0.0.1:5001
POKEMON_VERSION=red
POKEMON_ROM_PATH=/absolute/path/to/legal/rom.gb
EVIDENCE_DIR=runs
HARNESS_RUN_ID=
HARNESS_MODE=stage1
LOG_LEVEL=info
LOOP_MAX_STEPS=
LOOP_STEP_DELAY_MS=250
MAX_LLM_CALLS=
LLM_TIMEOUT_MS=20000
LLM_MAX_RETRIES=1
DEFAULT_TAP_FRAMES=5
DEFAULT_HOLD_FRAMES=15
# AI_PROVIDER may be heuristic or openai.
# For CodexLB, use AI_PROVIDER=openai and OPENAI_BASE_URL=https://codex.nekos.me/v1.
AI_PROVIDER=heuristic
OPENAI_BASE_URL=https://codex.nekos.me/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_TEMPERATURE=0.2
LLM_VISION_ENABLED=false
LLM_VISION_MAX_IMAGES=3
LLM_VISION_CROP_LEFT=0
LLM_VISION_CROP_TOP=0
LLM_VISION_CROP_WIDTH=0
LLM_VISION_CROP_HEIGHT=0
LLM_VISION_MAX_WIDTH=512
LLM_VISION_MAX_HEIGHT=384
LLM_VISION_FORMAT=jpeg
LLM_VISION_QUALITY=70
LLM_VISION_DETAIL=low
DEV_VIEWER_PORT=8787
START_MGBA_HTTP=1
START_MGBA=1
TMUX_SESSION=pss-mgba
