{
  "name": "typescript-pokemon-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "typecheck": "tsc --noEmit && pnpm web:typecheck",
    "test": "vitest run --passWithNoTests",
    "test:ci": "vitest run --passWithNoTests --fileParallelism=false",
    "dev": "tsx src/index.ts",
    "readiness": "tsx src/readiness.ts",
    "tui": "tsx src/tui.ts",
    "viewer": "tsx src/viewer-server-main.ts",
    "web:dev": "vite --config web/vite.config.ts",
    "web:build": "vite build --config web/vite.config.ts",
    "web:typecheck": "tsc -p tsconfig.web.json --noEmit",
    "web:preview": "vite preview --config web/vite.config.ts",
    "build": "tsc -p tsconfig.json",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "improve:trace": "tsx src/self-improvement.ts",
    "parallel:run": "tsx src/parallel-runner.ts",
    "trace:report": "tsx src/trace-report.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "3.0.0-canary.48",
    "@minpeter/pss-runtime": "^0.0.8",
    "@t3-oss/env-core": "^0.13.11",
    "ai": "7.0.0-canary.142",
    "dotenv": "17.4.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "ultracite": "7.7.0",
    "vite": "^8.0.14",
    "vitest": "4.1.7"
  }
}
