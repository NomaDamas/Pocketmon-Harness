{
  "name": "typescript-pokemon-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "trace:report": "tsx src/trace-report.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "3.0.0-canary.48",
    "@minpeter/pss-runtime": "^0.0.6",
    "@t3-oss/env-core": "^0.13.11",
    "ai": "7.0.0-canary.142",
    "dotenv": "17.4.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "25.9.1",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "ultracite": "7.7.0",
    "vitest": "4.1.7"
  }
}
