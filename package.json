{
  "name": "typescript-pokemon-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "check:secrets": "tsx scripts/check-no-secrets.ts",
    "harness": "tsx src/index.ts",
    "dev": "tsx src/dev.ts",
    "dev:tmux": "tsx scripts/dev-tmux.ts",
    "smoke:mgba": "tsx src/index.ts smoke",
    "build": "tsc -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "latest",
    "openai": "latest",
    "sharp": "^0.34.5",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
